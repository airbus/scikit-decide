#include "${CMAKE_SOURCE_DIR}/src/hub/solver/idual/idual.hh"
#include "${CMAKE_SOURCE_DIR}/src/hub/solver/idual/impl/idual_impl.hh"
#include "${CMAKE_SOURCE_DIR}/src/hub/solver/idual/py_idual.hh"
#include "${CMAKE_SOURCE_DIR}/src/utils/python_domain_proxy.hh"

// Unconstrained: class + SFINAE member get_best_action
template class skdecide::IDualSolver<
    skdecide::PythonDomainProxy<skdecide::${Texecution}>,
    skdecide::${Texecution}>;

template const skdecide::PythonDomainProxy<skdecide::${Texecution}>::Action &
skdecide::IDualSolver<
    skdecide::PythonDomainProxy<skdecide::${Texecution}>,
    skdecide::${Texecution}>::
    get_best_action<
        skdecide::PythonDomainProxy<skdecide::${Texecution}>, 0>(
        const skdecide::PythonDomainProxy<skdecide::${Texecution}>::State &)
        const;

template skdecide::MapTypeDeducer<
    skdecide::PythonDomainProxy<skdecide::${Texecution}>::State,
    std::pair<skdecide::PythonDomainProxy<skdecide::${Texecution}>::Action,
              skdecide::PythonDomainProxy<skdecide::${Texecution}>::Value>>::Map
skdecide::IDualSolver<
    skdecide::PythonDomainProxy<skdecide::${Texecution}>,
    skdecide::${Texecution}>::
    get_policy<
        skdecide::PythonDomainProxy<skdecide::${Texecution}>, 0>() const;

// Constrained: class + SFINAE member get_action_distribution
template class skdecide::IDualSolver<
    skdecide::PyConstrainedIDualDomain<skdecide::${Texecution}>,
    skdecide::${Texecution}>;

template std::vector<std::pair<
    skdecide::PyConstrainedIDualDomain<skdecide::${Texecution}>::Action,
    double>>
skdecide::IDualSolver<
    skdecide::PyConstrainedIDualDomain<skdecide::${Texecution}>,
    skdecide::${Texecution}>::
    get_action_distribution<
        skdecide::PyConstrainedIDualDomain<skdecide::${Texecution}>, 0>(
        const skdecide::PyConstrainedIDualDomain<
            skdecide::${Texecution}>::State &) const;

template skdecide::MapTypeDeducer<
    skdecide::PyConstrainedIDualDomain<skdecide::${Texecution}>::State,
    std::pair<std::vector<std::pair<skdecide::PyConstrainedIDualDomain<skdecide::${Texecution}>::Action, double>>,
              skdecide::PyConstrainedIDualDomain<skdecide::${Texecution}>::Value>>::Map
skdecide::IDualSolver<
    skdecide::PyConstrainedIDualDomain<skdecide::${Texecution}>,
    skdecide::${Texecution}>::
    get_policy<
        skdecide::PyConstrainedIDualDomain<skdecide::${Texecution}>, 0>() const;
