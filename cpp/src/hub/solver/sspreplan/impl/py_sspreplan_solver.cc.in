template class skdecide::SSPReplanSolver<
    skdecide::PythonDomainProxy<skdecide::${Texecution}>,
    skdecide::${Texecution},
    skdecide::TransitionDeterminizationAdapter<
        skdecide::PythonDomainProxy<skdecide::${Texecution}>,
        skdecide::${Tstrategy},
        skdecide::${Texecution}>>;

template class skdecide::DeterminizedDomain<
    skdecide::PythonDomainProxy<skdecide::${Texecution}>,
    skdecide::${Tstrategy},
    skdecide::${Texecution}>;

template class skdecide::TransitionDeterminizationAdapter<
    skdecide::PythonDomainProxy<skdecide::${Texecution}>,
    skdecide::${Tstrategy},
    skdecide::${Texecution}>;
