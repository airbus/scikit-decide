#ifndef SKDECIDE_INNER_SOLVER_REGISTRY_IMPL_HH
#define SKDECIDE_INNER_SOLVER_REGISTRY_IMPL_HH

#include "hub/solver/inner_solver/inner_solver_registry.hh"
#include "hub/solver/inner_solver/inner_solver_traits.hh"
#include "hub/solver/inner_solver/make_entry.hh"
#include "hub/solver/inner_solver/meta_inner_solver_proxy.hh"
#include "hub/solver/inner_solver/impl/meta_inner_solver_proxy_impl.hh"

@ENTRY_INCLUDES@

namespace skdecide {

template <typename Domain, typename Texecution>
std::vector<InnerSolverEntry<Domain, Texecution>>
build_inner_solver_registry() {
  std::vector<InnerSolverEntry<Domain, Texecution>> registry;
@ENTRY_CONDITIONALS@
  return registry;
}

template <typename Domain, typename Texecution>
const std::vector<InnerSolverEntry<Domain, Texecution>> &
get_inner_solver_registry() {
  static const auto registry =
      build_inner_solver_registry<Domain, Texecution>();
  return registry;
}

template <typename Domain, typename Texecution>
const InnerSolverEntry<Domain, Texecution> &
find_inner_solver(const std::string &name) {
  const auto &registry = get_inner_solver_registry<Domain, Texecution>();
  for (const auto &entry : registry) {
    if (name == entry.name)
      return entry;
  }
  std::string available;
  for (const auto &e : registry) {
    if (!available.empty())
      available += ", ";
    available += e.name;
  }
  throw std::runtime_error("Unknown inner solver: " + name +
                           ". Available: " + available);
}

} // namespace skdecide

#endif // SKDECIDE_INNER_SOLVER_REGISTRY_IMPL_HH
