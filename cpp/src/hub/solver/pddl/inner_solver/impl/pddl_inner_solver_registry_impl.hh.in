#ifndef SKDECIDE_PDDL_INNER_SOLVER_REGISTRY_IMPL_HH
#define SKDECIDE_PDDL_INNER_SOLVER_REGISTRY_IMPL_HH

#include "hub/solver/pddl/inner_solver/pddl_inner_solver_registry.hh"
#include "hub/solver/pddl/inner_solver/pddl_make_entry.hh"

@PDDL_ENTRY_INCLUDES@

namespace skdecide {

namespace pddl {

template <typename Texecution>
std::vector<PddlInnerSolverEntry<Texecution>>
build_pddl_inner_solver_registry() {
  std::vector<PddlInnerSolverEntry<Texecution>> registry;
@PDDL_ENTRY_LINES@
  return registry;
}

template <typename Texecution>
const std::vector<PddlInnerSolverEntry<Texecution>> &
get_pddl_inner_solver_registry() {
  static const auto registry =
      build_pddl_inner_solver_registry<Texecution>();
  return registry;
}

template <typename Texecution>
const PddlInnerSolverEntry<Texecution> &
find_pddl_inner_solver(const std::string &name) {
  const auto &registry = get_pddl_inner_solver_registry<Texecution>();
  for (const auto &entry : registry) {
    if (name == entry.name)
      return entry;
  }
  std::string available;
  for (const auto &e : registry) {
    if (!available.empty())
      available += ", ";
    available += e.name;
  }
  throw std::runtime_error("Unknown PDDL inner solver: " + name +
                           ". Available: " + available);
}

} // namespace pddl

} // namespace skdecide

#endif // SKDECIDE_PDDL_INNER_SOLVER_REGISTRY_IMPL_HH
